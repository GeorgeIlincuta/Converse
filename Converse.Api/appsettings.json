{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Whisper": {
    "ModelPath": "models/whisper/ggml-base.en.bin",
    "Language": "en"
  },
  "Supertonic": {
    "ModelPath": "models/supertonic/model.onnx"
  },
  "Llm": {
    "DefaultProvider": "openai-compatible",
    "Gemini": { "ApiKey": "", "Model": "gemini-2.5-flash" },
    "OpenAICompatible": { "BaseUrl": "http://localhost:1234", "Model": "local-model", "ApiKey": "" }
  },
  "Kestrel": {
    "Endpoints": {
      "Http": { "Url": "http://127.0.0.1:5000" }
    }
  }
}
